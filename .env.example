# Base URL for the Well of Wishes API (no trailing slash)
WOW_BASE_URL=https://api.wellofwishes.example.com

# Your community integration client key (provided by WoW)
COMMUNITY_LINK_CLIENT_KEY=your_client_key_here

# Shared secret for HMAC-SHA256 signing (NEVER expose to the frontend)
COMMUNITY_LINK_SHARED_SECRET=your_shared_secret_here

# Optional: default server/community ID used when creating new users
DEFAULT_SERVER_ID=community-server-1
